@{
    var book = ViewBag.Book as ASP.NET_MVC_LABs.Models.Book;
    ViewData["Title"] = book?.Title;
}

@if (book != null)
{
    <div class="container mt-4">
        <h1>@book.Title</h1>
        <div class="card">
            <div class="card-body">
                <p><strong>Автор:</strong> @book.Author</p>
                <p><strong>Год издания:</strong> @book.Year</p>
                <p><strong>ISBN:</strong> @book.ISBN</p>
                <!-- можно добавить описание и т.д. -->
            </div>
        </div>
        <a href="@Url.Action("Catalog")" class="btn btn-secondary mt-3">← Назад к каталогу</a>
    </div>
}
else
{
    <p>Книга не найдена.</p>
}