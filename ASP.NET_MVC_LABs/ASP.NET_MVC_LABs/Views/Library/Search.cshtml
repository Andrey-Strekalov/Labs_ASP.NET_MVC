@{
    ViewData["Title"] = "Поиск книг";
    var results = ViewBag.SearchResults as IEnumerable<dynamic>;
    var query = ViewBag.SearchQuery as string;
    var count = ViewBag.ResultsCount ?? 0;
}

<h1>Поиск книг</h1>

<form method="get" action="@Url.Action("Search")" class="form-inline mb-3">
    <div class="input-group">
        <input type="text" name="query" class="form-control form-control-lg"
               placeholder="Введите название, автора или год..." value="@query" />
        <div class="input-group-append">
            <button type="submit" class="btn btn-primary btn-lg">Найти</button>
        </div>
    </div>
</form>

@if (!string.IsNullOrEmpty(query))
{
    <h4>Результаты поиска по запросу «@query»: найдено @count книг</h4>

    @if (results != null && results.Any())
    {
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>Название</th>
                    <th>Автор</th>
                    <th>Год</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var book in results)
                {
                    <tr>
                        <td>
                            <a href="@Url.Action("Book", new { isbn = book.ISBN })">@book.Title</a>
                        </td>
                        <td>@book.Author</td>
                        <td>@book.Year</td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <div class="alert alert-warning">Ничего не найдено. Попробуйте изменить запрос.</div>
    }
}
else
{
    <p class="text-muted">Введите запрос для поиска.</p>
}

<div class="mt-3">
    <a href="@Url.Action("Index")" class="btn btn-secondary">← На главную</a>
    <a href="@Url.Action("Catalog")" class="btn btn-outline-secondary">Каталог</a>
</div>