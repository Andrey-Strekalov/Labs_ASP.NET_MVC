@{
    ViewData["Title"] = "Каталог книг";
}

<h1>Каталог книг</h1>

@{
    var books = ViewBag.BookList as IEnumerable<dynamic>;
}

@if (books != null && books.Any())
{
    <p class="text-muted">Всего книг: @books.Count()</p>

    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>Название</th>
                <th>Автор</th>
                <th>Год</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var book in books)
            {
                <tr>
                    <td>
                        <a href="@Url.Action("Book", new { isbn = book.ISBN })">@book.Title</a>
                    </td>
                    <td>@book.Author</td>
                    <td>@book.Year</td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <div class="alert alert-warning">Книги не найдены.</div>
}

<div class="mt-3">
    <a href="/library/home" class="btn btn-secondary">← Назад в библиотеку</a>
    <a href="@Url.Action("Search")" class="btn btn-info btn-lg">🔍 Поиск книг</a>
</div>