@{
    ViewData["Title"] = ViewBag.LibraryName;
}

<div class="container mt-4">
    <h1 class="display-4">@ViewBag.LibraryName</h1>

    <div class="card mt-4">
        <div class="card-body">
            @{
                // Разбиваем текст на абзацы для лучшей читаемости
                var text = ViewBag.AboutLibraryText as string;
                if (!string.IsNullOrEmpty(text))
                {
                    // Заменяем точки с пробелами на точки с переводом строки (для разделения на предложения)
                    var sentences = text.Split(new[] { ". " }, StringSplitOptions.RemoveEmptyEntries);
                    foreach (var sentence in sentences)
                    {
                        <p class="lead" style="text-indent: 1.5em;">@Html.Raw(sentence.Trim() + (sentence.EndsWith(".") ? "" : "."))</p>
                    }
                }
                else
                {
                    <p class="text-muted">Описание отсутствует.</p>
                }
            }
        </div>
    </div>

    <div class="mt-4 d-flex gap-2">
        <a href="@Url.Action("Catalog", "Library")" class="btn btn-primary btn-lg">📚 Каталог книг</a>
        <a href="@Url.Action("Index", "Home")" class="btn btn-outline-secondary btn-lg">🏠 На главную</a>
        <a href="@Url.Action("Search")" class="btn btn-info btn-lg">🔍 Поиск книг</a>
    </div>
</div>