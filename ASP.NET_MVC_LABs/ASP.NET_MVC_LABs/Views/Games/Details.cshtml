@model ASP.NET_MVC_LABs.Models.Game

@{
    ViewData["Title"] = "Детали игры";
}

<h1 class="mb-4">Детали игры</h1>

<div class="card">
    <div class="card-header bg-primary text-white">
        <h4>@Model.Title</h4>
    </div>
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-3">@Html.DisplayNameFor(model => model.Id)</dt>
            <dd class="col-sm-9">@Html.DisplayFor(model => model.Id)</dd>

            <dt class="col-sm-3">@Html.DisplayNameFor(model => model.Genre)</dt>
            <dd class="col-sm-9">@Html.DisplayFor(model => model.Genre)</dd>

            <dt class="col-sm-3">@Html.DisplayNameFor(model => model.Platform)</dt>
            <dd class="col-sm-9">@Html.DisplayFor(model => model.Platform)</dd>

            <dt class="col-sm-3">@Html.DisplayNameFor(model => model.ReleaseYear)</dt>
            <dd class="col-sm-9">@Html.DisplayFor(model => model.ReleaseYear)</dd>

            <dt class="col-sm-3">@Html.DisplayNameFor(model => model.Developer)</dt>
            <dd class="col-sm-9">@Html.DisplayFor(model => model.Developer)</dd>

            <dt class="col-sm-3">@Html.DisplayNameFor(model => model.Rating)</dt>
            <dd class="col-sm-9">
                <span class="badge bg-info">@Model.Rating</span>
            </dd>

            <dt class="col-sm-3">@Html.DisplayNameFor(model => model.IsMultiplayer)</dt>
            <dd class="col-sm-9">
                @if (Model.IsMultiplayer)
                {
                    <span class="badge bg-success">Да</span>
                }
                else
                {
                    <span class="badge bg-secondary">Нет</span>
                }
            </dd>

            <dt class="col-sm-3">@Html.DisplayNameFor(model => model.CreatedDate)</dt>
            <dd class="col-sm-9">@Html.DisplayFor(model => model.CreatedDate)</dd>
        </dl>
    </div>
    <div class="card-footer">
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">
            <i class="bi bi-pencil"></i> Редактировать
        </a>
        <a asp-action="Index" class="btn btn-secondary">
            <i class="bi bi-arrow-left"></i> Вернуться к списку
        </a>
    </div>
</div>