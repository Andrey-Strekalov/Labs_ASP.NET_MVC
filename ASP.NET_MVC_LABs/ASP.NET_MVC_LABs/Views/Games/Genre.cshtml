@model IEnumerable<ASP.NET_MVC_LABs.Models.Game>

@{
    ViewData["Title"] = $"Игры жанра {ViewBag.Genre}";
}

<h1 class="mb-4">Игры жанра: <span class="badge bg-secondary">@ViewBag.Genre</span></h1>

<p>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-circle"></i> Добавить новую игру
    </a>
    <a asp-action="Index" class="btn btn-secondary">
        <i class="bi bi-arrow-left"></i> Все игры
    </a>
</p>

<table class="table table-striped table-hover">
    <thead class="table-dark">
        <tr>
            <th>@Html.DisplayNameFor(model => model.Id)</th>
            <th>@Html.DisplayNameFor(model => model.Title)</th>
            <th>@Html.DisplayNameFor(model => model.Genre)</th>
            <th>@Html.DisplayNameFor(model => model.Platform)</th>
            <th>@Html.DisplayNameFor(model => model.ReleaseYear)</th>
            <th>@Html.DisplayNameFor(model => model.Developer)</th>
            <th>@Html.DisplayNameFor(model => model.Rating)</th>
            <th>@Html.DisplayNameFor(model => model.IsMultiplayer)</th>
            <th>Действия</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@Html.DisplayFor(modelItem => item.Id)</td>
                <td>@Html.DisplayFor(modelItem => item.Title)</td>
                <td>@Html.DisplayFor(modelItem => item.Genre)</td>
                <td>@Html.DisplayFor(modelItem => item.Platform)</td>
                <td>@Html.DisplayFor(modelItem => item.ReleaseYear)</td>
                <td>@Html.DisplayFor(modelItem => item.Developer)</td>
                <td>
                    <span class="badge bg-info text-dark">@item.Rating</span>
                </td>
                <td>
                    @if (item.IsMultiplayer)
                    {
                        <span class="badge bg-success">Да</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary">Нет</span>
                    }
                </td>
                <td>
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info" title="Детали">
                        <i class="bi bi-eye"></i>
                    </a>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning" title="Редактировать">
                        <i class="bi bi-pencil"></i>
                    </a>
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger" title="Удалить">
                        <i class="bi bi-trash"></i>
                    </a>
                </td>
            </tr>
        }
    </tbody>
</table>